{
  "compilerOptions": {
    // Type Checking
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    // Modules
    // Нужно поменять при обновлении TS на 6 версию.
    "baseUrl": "src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "app": ["app"],
      "components": ["components"],
      "providers": ["providers"],
      "features": ["features"],
      "pages": ["pages"],
      "shared": ["shared"]
    },
    "resolveJsonModule": true,
    "sourceMap": true,
    // JavaScript Support
    "allowJs": true,
    // Interop
    "esModuleInterop": true,
    "isolatedModules": true, // vite requires
    // Language and Environment
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "target": "esnext",
    "useDefineForClassFields": true,
    // Completeness
    "skipLibCheck": true,
    "types": ["node", "jest", "@testing-library/jest-dom"]
  }
}